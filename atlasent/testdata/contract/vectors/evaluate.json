{
  "$schema": "../schemas/evaluate-request.schema.json",
  "description": "Round-trip vectors for POST /v1-evaluate. Every SDK MUST: (a) serialize `sdk_input` into exactly `wire_request` on the wire; (b) when the server returns `wire_response`, produce `sdk_output` (keys in the idiomatic casing of that language).",
  "vectors": [
    {
      "name": "evaluate_allow_minimal",
      "description": "Minimal ALLOW. No context supplied by the caller; SDK MUST default context to {}.",
      "sdk_input": {
        "agent": "clinical-data-agent",
        "action": "read_patient_record"
      },
      "api_key": "ask_live_test_key",
      "wire_request": {
        "action": "read_patient_record",
        "agent": "clinical-data-agent",
        "context": {},
        "api_key": "ask_live_test_key"
      },
      "wire_response": {
        "permitted": true,
        "decision_id": "dec_minimal_allow_001",
        "reason": "",
        "audit_hash": "hash_a1b2c3",
        "timestamp": "2026-04-17T10:00:00Z"
      },
      "sdk_output": {
        "decision": "ALLOW",
        "permitted": true,
        "permit_id": "dec_minimal_allow_001",
        "reason": "",
        "audit_hash": "hash_a1b2c3",
        "timestamp": "2026-04-17T10:00:00Z"
      }
    },
    {
      "name": "evaluate_allow_with_context",
      "description": "ALLOW with a rich context object. Context MUST be forwarded verbatim; no key remapping.",
      "sdk_input": {
        "agent": "clinical-data-agent",
        "action": "modify_patient_record",
        "context": {
          "user": "dr_smith",
          "environment": "production",
          "patient_id": "PT-001",
          "change_reason": "Correct date-of-birth"
        }
      },
      "api_key": "ask_live_test_key",
      "wire_request": {
        "action": "modify_patient_record",
        "agent": "clinical-data-agent",
        "context": {
          "user": "dr_smith",
          "environment": "production",
          "patient_id": "PT-001",
          "change_reason": "Correct date-of-birth"
        },
        "api_key": "ask_live_test_key"
      },
      "wire_response": {
        "permitted": true,
        "decision_id": "dec_ctx_allow_002",
        "reason": "Operator authorized under GxP policy",
        "audit_hash": "hash_ctx_002",
        "timestamp": "2026-04-17T10:01:00Z"
      },
      "sdk_output": {
        "decision": "ALLOW",
        "permitted": true,
        "permit_id": "dec_ctx_allow_002",
        "reason": "Operator authorized under GxP policy",
        "audit_hash": "hash_ctx_002",
        "timestamp": "2026-04-17T10:01:00Z"
      }
    },
    {
      "name": "evaluate_deny_no_throw",
      "description": "DENY MUST be returned as data, NOT thrown as a transport error. Public authorize() / evaluate() surfaces MAY raise — but the HTTP layer MUST treat this as a normal 200.",
      "sdk_input": {
        "agent": "finance-agent",
        "action": "wire_transfer",
        "context": { "amount_usd": 50000 }
      },
      "api_key": "ask_live_test_key",
      "wire_request": {
        "action": "wire_transfer",
        "agent": "finance-agent",
        "context": { "amount_usd": 50000 },
        "api_key": "ask_live_test_key"
      },
      "wire_response": {
        "permitted": false,
        "decision_id": "dec_deny_003",
        "reason": "Amount exceeds agent limit",
        "audit_hash": "hash_deny_003",
        "timestamp": "2026-04-17T10:02:00Z"
      },
      "sdk_output": {
        "decision": "DENY",
        "permitted": false,
        "permit_id": "dec_deny_003",
        "reason": "Amount exceeds agent limit",
        "audit_hash": "hash_deny_003",
        "timestamp": "2026-04-17T10:02:00Z"
      }
    },
    {
      "name": "evaluate_response_missing_required_fields",
      "description": "Malformed response: missing `permitted` or `decision_id`. SDKs MUST raise a bad-response error (do NOT silently default to DENY or ALLOW).",
      "sdk_input": { "agent": "a", "action": "b" },
      "api_key": "ask_live_test_key",
      "wire_request": {
        "action": "b",
        "agent": "a",
        "context": {},
        "api_key": "ask_live_test_key"
      },
      "wire_response": { "foo": "bar" },
      "sdk_error": {
        "kind": "bad_response",
        "message_contains": "permitted"
      }
    }
  ]
}
